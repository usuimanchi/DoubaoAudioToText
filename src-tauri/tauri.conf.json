{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "豆包语音转文字",
  "version": "0.3.0",
  "identifier": "com.amamizu.doubao-transcriber",
  "build": {
    "frontendDist": "../frontend",
    "beforeBuildCommand": "",
    "beforeDevCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "豆包语音转文字",
        "width": 800,
        "height": 700,
        "resizable": true,
        "dragDropEnabled": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc://localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [],
    "resources": [
      "binaries/ffmpeg*",
      "binaries/ffprobe*"
    ]
  }
}
